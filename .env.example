OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=nexus_learner_mvp

# Database
# DB_URL=sqlite:///./nexus_v3.db
DB_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Modal (Serverless Backend)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# GROQ / Google / DeepSeek (Optional)
GROQ_API_KEY=your-groq-api-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Semantic Cache (Qdrant-backed, local sentence-transformers embeddings)
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.92
# SEMANTIC_CACHE_EXCLUDE_SCHEMAS=FlashcardOutput   # comma-separated if overriding

# Embeddings: "openai" (default, 1536 dims) or "huggingface" (local, 384 dims, no key needed)
EMBEDDING_PROVIDER=openai

# Model hopping (free-tier multi-provider routing via LiteLLM)
MODEL_HOP_ENABLED=false
MODEL_HOP_PRIMARY_TIER=balanced
MODEL_HOP_ROUTING_TIER=fast

# Agent-level semantic cache (requires core/cache.py + Qdrant)
AGENT_CACHE_ENABLED=false

# Card generation limits (hard cap: 50 for both)
# MAX_CARDS_PER_PDF=3          # Total cards per generation run per document (safety net)
# MAX_CARDS_PER_TOPIC_TYPE=5   # Cards per topic per question type; re-runs fill remaining capacity

# ---------------------------------------------------------------------------
# Test database (.env.test overrides these — copy this block into .env.test)
# Start with: docker-compose up -d test-db
# ---------------------------------------------------------------------------
# DB_URL=postgresql://postgres:postgres@localhost:5433/nexus_test
# QDRANT_COLLECTION_NAME=nexus_chunks_test
# MAX_CARDS_PER_PDF=8
# MAX_CARDS_PER_TOPIC_TYPE=2